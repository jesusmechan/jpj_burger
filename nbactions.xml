<?xml version="1.0" encoding="UTF-8"?>
<actions>
    <action>
        <actionName>run</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.5.0:java</goal>
        </goals>
        <properties>
            <exec.mainClass>com.mycompany.jpj_burgers.Jpj_burgers</exec.mainClass>
        </properties>
    </action>
    <action>
        <actionName>debug</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.5.0:java</goal>
        </goals>
        <properties>
            <exec.mainClass>com.mycompany.jpj_burgers.Jpj_burgers</exec.mainClass>
            <jpda.listen>true</jpda.listen>
        </properties>
    </action>
</actions>
